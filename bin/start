#!/bin/bash

# Smileyan Backend 启动脚本

# 获取脚本所在目录
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

# 加载环境变量
if [ -f "$PROJECT_DIR/.env" ]; then
    export $(cat "$PROJECT_DIR/.env" | grep -v '^#' | xargs)
fi

# 检查端口是否被占用
if lsof -i :8080 > /dev/null 2>&1; then
    echo "端口 8080 已被占用，尝试停止旧进程..."
    lsof -i :8080 | grep LISTEN | awk '{print $2}' | xargs kill 2>/dev/null
    sleep 1
fi

cd "$PROJECT_DIR"

echo "启动 Smileyan Backend..."
go run main.go > logs/app.log 2>&1 &
PID=$!

echo $PID > logs/app.pid
echo "服务已启动，PID: $PID"
echo "日志文件: $PROJECT_DIR/logs/app.log"
